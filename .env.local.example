# ── MercadoPago ───────────────────────────────────────────────
# Obtené tus credenciales en: https://www.mercadopago.com.uy/developers/panel
# Usar prefijo TEST- para sandbox, sin prefijo para producción
MP_ACCESS_TOKEN=TEST-your-access-token-here
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-your-public-key-here

# ── URL pública de la app ─────────────────────────────────────
# Necesaria para las redirecciones y webhooks de MercadoPago
# En desarrollo podés usar ngrok: https://ngrok.com
NEXT_PUBLIC_URL=https://tu-dominio.com

# ── Resend (emails) ───────────────────────────────────────────
# Crear cuenta en: https://resend.com (plan gratis: 3000 emails/mes)
RESEND_API_KEY=re_your-api-key-here
# Una vez verificado el dominio santajusta.com.uy, cambiar a: pedidos@santajusta.com.uy
# Mientras tanto usar: onboarding@resend.dev (solo funciona para enviar a tu propio email de Resend)
RESEND_FROM=onboarding@resend.dev

# ── Emails ────────────────────────────────────────────────────
OWNER_EMAIL=emirod1955@gmail.com
